# Frontend build
VITE_CRYSTALBIO_API_URL=https://your-crystalbio-api.example.com

# Backend/API service
HOST=0.0.0.0
PORT=8787
CRYSTALBIO_DB_PATH=/private/persistent/crystalbio-db.json
CRYSTALBIO_ALLOWED_ORIGIN=https://your-crystalbio-frontend.example.com
CRYSTALBIO_SEED_DEMO=false
CRYSTALBIO_DEMO_PASSWORD=replace-with-private-pilot-password
CRYSTALBIO_REQUEST_LIMIT_BYTES=1048576
CRYSTALBIO_APP_BASE_URL=https://work.convogenie.ai

# Production database staging/cutover scaffold
# Keep CRYSTALBIO_PERSISTENCE=json until staging migration + Bloom QA + approval pass.
CRYSTALBIO_PERSISTENCE=json
# CRYSTALBIO_POSTGRES_URL=postgres://user:password@host:5432/crystalbio

# Private photo/file storage staging scaffold
# Use local_migration_placeholder only for local/staging migration rehearsals.
# Final production should use r2 or s3 after private bucket credentials are configured.
# CRYSTALBIO_FILE_STORAGE=local_migration_placeholder
# CRYSTALBIO_FILE_STORAGE_LOCAL_DIR=/private/persistent/crystalbio-file-migration
# CRYSTALBIO_R2_BUCKET=crystalbio-private-files
# CRYSTALBIO_R2_ACCOUNT_ID=replace-with-account-id
# CRYSTALBIO_R2_ACCESS_KEY_ID=replace-with-private-key-id
# CRYSTALBIO_R2_SECRET_ACCESS_KEY=replace-with-private-secret
# CRYSTALBIO_S3_BUCKET=crystalbio-private-files
# CRYSTALBIO_S3_REGION=ap-south-1
# CRYSTALBIO_S3_ACCESS_KEY_ID=replace-with-private-key-id
# CRYSTALBIO_S3_SECRET_ACCESS_KEY=replace-with-private-secret

# Recommended: Resend email delivery for invites / forgot password / sign-in links
CRYSTALBIO_EMAIL_PROVIDER=resend
CRYSTALBIO_EMAIL_FROM="CrystalBio Field App <no-reply@your-verified-domain.example>"
CRYSTALBIO_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: SMTP email delivery
# CRYSTALBIO_SMTP_HOST=smtp.your-provider.example
# CRYSTALBIO_SMTP_PORT=587
# CRYSTALBIO_SMTP_SECURE=false
# CRYSTALBIO_SMTP_USER=replace-with-smtp-user
# CRYSTALBIO_SMTP_PASS=replace-with-smtp-password
